# Copy this file to .env and fill in your values before starting the bot.
# NEVER commit .env to git!

# Telegram Bot token (from @BotFather)
BOT_TOKEN=1234567890:replace_me

# Telegram API credentials (from https://my.telegram.org)
API_ID=123456
API_HASH=replace_me

# Bot owner username (without @)
OWNER_USERNAME=your_username

# Path where runtime data (SQLite DB, JSON files) will be stored
# On VPS: /opt/telegram-bot2/data  or  /data
DATA_DIR=/data

# Optional tuning
BOT_THREADS=8
DB_FLUSH_INTERVAL_SECONDS=2
GLOBAL_LAST_SEEN_UPDATE_SECONDS=60
TG_CACHE_MEMBER_TTL=15
TG_CACHE_CHAT_TTL=60
